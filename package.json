{
  "name": "grocery-expiry-tracker-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "description": "Full Stack Grocery Expiry Tracker Workspace",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "start:backend": "npm run start --prefix backend",
    "start:frontend": "npm run start --prefix frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "concurrently --kill-others \"npm run start:backend\" \"npm run start:frontend\"",
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\"",
    "prod": "npm run build && concurrently --kill-others \"npm run start:backend\" \"npm run start:frontend\""
  },
  "dependencies": {
    "concurrently": "^10.0.0"
  }
}
